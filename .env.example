EMAIL_ENABLED=true
EMAIL_TIME=09:00
EMAIL_TIMEZONE=Europe/Lisbon
EMAIL_HOST=mail.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_USER=you@example.com
EMAIL_PASS=your-email-password
EMAIL_TO=recipient@example.com
AUTH_ENABLED=true
APP_USER=your-username
APP_PASS=your-password
APP_URL=https://your-private-app-url.example.com/
PLAYGROUND_MODE=false
DATA_FILE=/var/data/lists.json
STORAGE_BACKEND=json

# Use these only when STORAGE_BACKEND=supabase.
# Keep the secret/service key in .env or your hosting provider secrets, never in GitHub.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-secret-or-service-role-key
SUPABASE_TABLE=app_state
SUPABASE_STATE_ID=main
